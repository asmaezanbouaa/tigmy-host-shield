# Railway production — admin login (set in Railway → Variables)

ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# Optional second admin (co-host)
ADMIN_USERNAME_2=mamourimehdi
ADMIN_PASSWORD_2=your-secure-password

# On every deploy/restart, passwords are synced from these variables.
# Add a Volume in Railway Settings mounted at /app/data (and /app/storage)
# so guest submissions survive redeploys.

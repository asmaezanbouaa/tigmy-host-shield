# Application
APP_NAME=Tigmy Host Shield
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# Server (use HTTPS in production behind reverse proxy)
HOST=0.0.0.0
PORT=8000
BASE_URL=http://localhost:8000
FORCE_HTTPS=false

# Database (SQLite default; use PostgreSQL in production)
DATABASE_URL=sqlite:///./data/guest_registry.db

# Storage paths (relative to project root)
STORAGE_PATH=./storage
SIGNATURES_DIR=signatures
PDFS_DIR=pdfs
ID_DOCUMENTS_DIR=id_documents
ARCHIVE_EXPORTS_DIR=archive_exports

# ID scan: deleted this many hours after admin marks as verified
ID_RETENTION_HOURS_AFTER_VERIFY=14

# Archive: minimum days between quarterly purges (download ZIP first)
ARCHIVE_PURGE_INTERVAL_DAYS=90

# Admin session
SESSION_COOKIE_NAME=guest_registry_admin
SESSION_MAX_AGE_HOURS=24

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

DEFAULT_LINK_EXPIRY_DAYS=30

RULES_FR_PATH=./config/rules_fr.txt
RULES_EN_PATH=./config/rules_en.txt
RULES_AR_PATH=./config/rules_ar.txt

# AI ID check — pick ONE (local = unlimited free, no daily quota)
# local | gemini | openai | off
AI_PROVIDER=local

# Option A — Local OCR (UNLIMITED FREE — needs Tesseract on the server)
# sudo apt install tesseract-ocr tesseract-ocr-fra
# pip install pytesseract

# Option B — Google Gemini (free API key, daily quota limit)
# https://aistudio.google.com/apikey — key must start with AIza
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Option C — OpenAI (PAID — needs billing credits for vision)
# AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
